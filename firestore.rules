rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // السماح بالقراءة والكتابة لجميع المستخدمين (لأغراض التطوير والنشر السريع)
      // ملاحظة: في المستقبل يفضل تقييد هذه القواعد بناءً على تسجيل الدخول
      allow read, write: if true;
    }
  }
}