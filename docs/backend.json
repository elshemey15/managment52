
{
  "entities": {
    "Supplier": {
      "title": "Supplier",
      "description": "Supplier profile with financial balances",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "balance": { "type": "number" },
        "totalPurchases": { "type": "number" },
        "totalPayments": { "type": "number" }
      },
      "required": ["name", "balance"]
    },
    "PurchaseInvoice": {
      "title": "Purchase Invoice",
      "description": "Invoice for inventory replenishment from a supplier",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date-time" },
        "totalValue": { "type": "number" },
        "paidAmount": { "type": "number" },
        "remainingAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["PAID", "PARTIAL", "UNPAID"] }
      }
    },
    "SupplierPayment": {
      "title": "Supplier Payment",
      "description": "A payment record made to settle supplier debts",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "method": { "type": "string", "enum": ["CASH", "TRANSFER", "CHECK"] },
        "note": { "type": "string" }
      }
    },
    "Item": {
      "title": "Inventory Item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string" },
        "departmentId": { "type": "string" },
        "unitId": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "salePrice": { "type": "number" },
        "currentStock": { "type": "number" }
      }
    },
    "CashTransaction": {
      "title": "Cash Transaction",
      "description": "Records of sent or received cash/transfers",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["SEND", "RECEIVE"] },
        "personName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "timestamp": { "type": "string" },
        "userId": { "type": "string" }
      }
    },
    "GeneralInvoice": {
      "title": "General Invoice",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "day": { "type": "string" },
        "invoiceCount": { "type": "number" },
        "salePrice": { "type": "number" },
        "expenses": { "type": "number" },
        "note": { "type": "string" }
      }
    },
    "Movement": {
      "title": "Inventory Movement",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "type": { "type": "string", "enum": ["IN", "OUT"] },
        "quantity": { "type": "number" },
        "priceAtTime": { "type": "number" },
        "userId": { "type": "string" },
        "timestamp": { "type": "object" },
        "note": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "type": "object", "properties": { "username": { "type": "string" }, "role": { "type": "string" }, "password": { "type": "string" } } }, "description": "Users database" },
    "/suppliers/{supplierId}": { "schema": "Supplier", "description": "Suppliers database" },
    "/purchases/{purchaseId}": { "schema": "PurchaseInvoice", "description": "Purchases history" },
    "/payments/{paymentId}": { "schema": "SupplierPayment", "description": "Payments ledger" },
    "/items/{itemId}": { "schema": "Item", "description": "Inventory ledger" },
    "/departments/{deptId}": { "schema": { "type": "object", "properties": { "name": { "type": "string" } } }, "description": "Inventory Departments" },
    "/units/{unitId}": { "schema": { "type": "object", "properties": { "name": { "type": "string" } } }, "description": "Units of measure" },
    "/expenses/{expenseId}": { "schema": "Expense", "description": "General expenses" },
    "/cash_transactions/{transId}": { "schema": "CashTransaction", "description": "Cash and transfers ledger" },
    "/general_invoices/{invId}": { "schema": "GeneralInvoice", "description": "Daily total invoices" },
    "/movements/{moveId}": { "schema": "Movement", "description": "Detailed inventory movements" }
  }
}
